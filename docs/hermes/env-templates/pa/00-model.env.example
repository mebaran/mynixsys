# Personal assistant profile model credentials.
# Required when model.provider is openrouter.
OPENROUTER_API_KEY=replace-me

# Optional provider keys for direct provider use or auxiliary tools.
# GOOGLE_API_KEY=replace-me
# GEMINI_API_KEY=replace-me

# Codex auth normally lives in CODEX_HOME after `hermes-codex-login pa`.
# Only set OPENAI_API_KEY if you intentionally use API-key based Codex/OpenAI
# auth instead of device login.
# OPENAI_API_KEY=replace-me

# Optional: name advertised by the OpenAI-compatible API server.
API_SERVER_MODEL_NAME=hermes-pa
