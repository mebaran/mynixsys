# Orchestrator Telegram bot. This is the recommended bot for Kanban intake.
TELEGRAM_BOT_TOKEN=replace-me

# Restrict bot access to your Telegram numeric user IDs.
# Get your ID by messaging @userinfobot.
TELEGRAM_ALLOWED_USERS=replace-me

# Delivery target for Kanban notifications and cross-platform messages.
# For DMs, use your Telegram numeric user ID.
TELEGRAM_HOME_CHANNEL=replace-me
TELEGRAM_HOME_CHANNEL_NAME=Orchestrator

# Long polling is the recommended default. Only set webhook variables if you
# have a public HTTPS endpoint for this bot.
# TELEGRAM_WEBHOOK_URL=https://example.com/telegram-orchestrator
# TELEGRAM_WEBHOOK_PORT=8442
# TELEGRAM_WEBHOOK_SECRET=replace-me
