# Optional Google API key for Gemini/model and auxiliary provider use.
# This is not the Gmail/Calendar OAuth credential.
GOOGLE_API_KEY=replace-me
GEMINI_API_KEY=replace-me

# Google Workspace Gmail/Calendar auth is profile-scoped JSON state, not env.
# For orchestrator, those files live inside the guest at:
# /var/lib/hermes/google_client_secret.json
# /var/lib/hermes/google_token.json
