# GitHub access for coding workspaces.
# The bundled GitHub skills check GITHUB_TOKEN. gh also honors GH_TOKEN.
GITHUB_TOKEN=replace-me
GH_TOKEN=replace-me

# Optional convenience values for your own scripts/skills.
GITHUB_OWNER=replace-me
CODER_WORKSPACE=/var/lib/hermes/profiles/coder/workspace
CODER_REPOS_DIR=/var/lib/hermes/profiles/coder/workspace/repos
