# Required because the profile API server binds to 0.0.0.0.
# Generate with: openssl rand -hex 32
API_SERVER_KEY=replace-me

# Optional CORS allowlist for browser clients.
# API_SERVER_CORS_ORIGINS=https://example.com,http://localhost:3000

# Optional generic webhook secret.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=replace-me

